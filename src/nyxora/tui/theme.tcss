/* ═══════════════════════════════════════════════════════════════
   NYXORA v3.0.0 "Nexus" — Obsidian Tactical Theme
   Amber #C89A30 · Near-black #0B0D12 · Obsidian Tactical palette
   ═══════════════════════════════════════════════════════════════ */

/* ── Global ──────────────────────────────────────────────────── */

Screen {
    background: #0B0D12;
}

/* ── App layout ──────────────────────────────────────────────── */

#app-header {
    height: 1;
    background: #0F1218;
    border-bottom: tall #1A2430;
    color: #C89A30;
    text-style: bold;
    padding: 0 1;
}

#app-body {
    layout: horizontal;
    height: 1fr;
}

/* ── Sidebar ─────────────────────────────────────────────────── */

#sidebar {
    width: 24;
    background: #0C1017;
    border-right: tall #1A2430;
    height: 1fr;
    layout: vertical;
}

#sidebar-title {
    height: 1;
    background: #0C1017;
    color: #2E3C4A;
    text-style: bold;
    padding: 0 1;
    border-bottom: tall #141C24;
}

#sidebar-footer {
    height: 2;
    background: #080A0E;
    border-top: tall #141C24;
    color: #222E3A;
    padding: 0 1;
}

ListView {
    background: #0C1017;
    border: none;
    height: 1fr;
    padding: 0;
}

ListItem {
    background: #0C1017;
    border-left: tall transparent;
    height: 2;
    padding: 0 1;
    color: #6A7A88;
}

ListItem:hover {
    background: #1A2230;
    color: #A8B8C8;
}

ListItem.--highlight {
    background: #111500;
    border-left: tall #C89A30;
    color: #C89A30;
    text-style: bold;
}

.nav-key {
    color: #2E3C4A;
}

ListItem.--highlight .nav-key {
    color: #8A6D10;
}

/* ── Workspace ───────────────────────────────────────────────── */

#workspace {
    background: #0B0D12;
    height: 1fr;
    padding: 1 2;
    overflow-y: auto;
}

ContentSwitcher {
    background: #0B0D12;
    height: 1fr;
}

/* ── Screen titles ───────────────────────────────────────────── */

.screen-title {
    color: #C89A30;
    text-style: bold;
    height: 1;
    padding: 0 0 1 0;
}

.screen-subtitle {
    color: #344252;
    height: 1;
}

/* ── Manage screen — two-panel layout ───────────────────────── */

#manage-layout {
    layout: horizontal;
    height: 1fr;
}

#entry-list-panel {
    width: 30;
    background: #0B0D12;
    border-right: tall #1A2430;
    height: 1fr;
    layout: vertical;
}

#entry-search-wrap {
    height: 3;
    border-bottom: tall #1A2430;
    background: #0B0D12;
    padding: 0;
}

#entry-search {
    background: #0B0D12;
    border: none;
    color: #E8D5A8;
    height: 3;
    padding: 0 1;
}

#entry-search:focus {
    border: none;
    background: #0D0A00;
}

#entry-items {
    background: #0B0D12;
    border: none;
    height: 1fr;
    padding: 0;
}

.entry-item {
    height: 2;
    border-left: tall transparent;
    padding: 0 1;
    background: #0B0D12;
    color: #6A7A88;
}

.entry-item:hover {
    background: #0D1016;
    color: #A8B8C8;
}

.entry-item.selected {
    background: #111500;
    border-left: tall #C89A30;
    color: #E8D5A8;
    text-style: bold;
}

.entry-sub {
    color: #344252;
}

#entry-detail-panel {
    background: #0B0D12;
    padding: 1 2;
    height: 1fr;
}

#entry-detail-scroll {
    background: #0B0D12;
    border: none;
    height: 1fr;
}

.entry-detail-title {
    color: #C89A30;
    text-style: bold;
    height: 1;
}

.field-label {
    color: #344252;
    width: 14;
}

.field-value {
    color: #A8B8C8;
}

.field-pw {
    color: #445462;
}

.field-url {
    color: #3A7A9A;
}

.field-totp {
    color: #2A7A4A;
    text-style: bold;
}

.field-tags {
    color: #C89A30;
}

.field-notes {
    color: #556070;
}

/* ── Strength classes ────────────────────────────────────────── */

.sw { color: #CC3333; }
.sf { color: #C89A30; }
.sg { color: #3A7A9A; }
.se { color: #2A7A4A; }

/* ── Section cards ───────────────────────────────────────────── */

.info-card {
    background: #0D1016;
    border: tall #1A2430;
    padding: 1;
    height: auto;
    margin-bottom: 1;
}

.info-card-title {
    color: #344252;
    text-style: bold;
    height: 1;
}

.info-card-value {
    color: #A8B8C8;
    height: 1;
}

/* ── Vault status ─────────────────────────────────────────────── */

/* Status classes — colour only, no borders or size overrides */
/* Applied to #app-header and vault status badge */
.status-unlocked {
    color: #2A7A4A;
}

.status-locked {
    color: #CC3333;
}

/* ── Buttons ──────────────────────────────────────────────────── */

Button {
    background: #111820;
    border: tall #2A3440;
    color: #8A9AA8;
    height: 3;
    margin-right: 1;
}

Button:hover {
    background: #1A2230;
    border: tall #3A4450;
    color: #E8D5A8;
}

Button:focus {
    border: tall #C89A30;
}

Button.primary {
    background: #0D0A00;
    border: tall #C89A30;
    color: #C89A30;
}

Button.primary:hover {
    background: #1A1400;
}

Button.danger {
    background: #0A0606;
    border: tall #CC3333;
    color: #CC3333;
}

Button.danger:hover {
    background: #180808;
}

Button.success {
    background: #060E08;
    border: tall #2A7A4A;
    color: #2A7A4A;
}

Button.success:hover {
    background: #0A1808;
}

/* ── Input fields ─────────────────────────────────────────────── */

Input {
    background: #0D1218;
    border: tall #1A2430;
    color: #E8D5A8;
    height: 3;
    padding: 0 1;
}

Input:focus {
    border: tall #C89A30;
    background: #0D0A00;
}

Input.-invalid {
    border: tall #CC3333;
}

TextArea {
    background: #0D1218;
    border: tall #1A2430;
    color: #E8D5A8;
    min-height: 5;
    padding: 1;
}

TextArea:focus {
    border: tall #C89A30;
}

/* ── Form labels ──────────────────────────────────────────────── */

.form-label {
    color: #344252;
    text-style: bold;
    height: 1;
    padding: 0 0 0 0;
}

.form-error {
    color: #CC3333;
    height: 1;
}

.form-hint {
    color: #2E3C4A;
    height: 1;
}

/* ── Progress bar ─────────────────────────────────────────────── */

ProgressBar {
    background: #1A2430;
    height: 1;
}

ProgressBar > .bar--bar {
    background: #C89A30;
}

ProgressBar.pw-weak > .bar--bar { background: #CC3333; }
ProgressBar.pw-fair > .bar--bar { background: #C89A30; }
ProgressBar.pw-strong > .bar--bar { background: #3A7A9A; }
ProgressBar.pw-excellent > .bar--bar { background: #2A7A4A; }

/* ── Radio / toggle ───────────────────────────────────────────── */

RadioSet {
    background: #0B0D12;
    border: none;
    height: auto;
    layout: horizontal;
}

RadioButton {
    background: #0D1218;
    border: tall #1A2430;
    color: #6A7A88;
    height: 3;
    padding: 0 1;
    margin-right: 1;
}

RadioButton:hover {
    color: #A8B8C8;
    border: tall #2A3440;
}

RadioButton.-selected {
    background: #0D0A00;
    border: tall #C89A30;
    color: #C89A30;
}

/* ── Checkbox ─────────────────────────────────────────────────── */

Checkbox {
    background: #0B0D12;
    color: #6A7A88;
    border: none;
    height: 1;
    margin-right: 2;
}

Checkbox:hover {
    color: #A8B8C8;
}

Checkbox.-on {
    color: #C89A30;
}

/* ── Slider ───────────────────────────────────────────────────── */

Slider {
    background: #1A2430;
    height: 1;
    margin: 1 0;
}

Slider > .slider--slider {
    background: #C89A30;
}

/* ── DataTable ────────────────────────────────────────────────── */

DataTable {
    background: #0B0D12;
    border: none;
    color: #6A7A88;
    height: auto;
}

DataTable > .datatable--header {
    background: #0D1016;
    color: #344252;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #111500;
    color: #E8D5A8;
}

DataTable > .datatable--even-row {
    background: #0D1016;
}

/* ── Protocol list (recovery screen) ─────────────────────────── */

.protocol-item {
    background: #0D1016;
    border: tall #1A2430;
    height: 3;
    padding: 0 1;
    color: #6A7A88;
    margin-bottom: 1;
}

.protocol-item:hover {
    border: tall #2A3440;
    color: #A8B8C8;
}

.protocol-item.active {
    background: #0D0A00;
    border: tall #C89A30;
    color: #C89A30;
}

/* ── Version compare boxes (updates screen) ───────────────────── */

#version-compare {
    layout: horizontal;
    height: auto;
    margin-bottom: 1;
}

.version-box {
    background: #0D1016;
    border: tall #1A2430;
    height: 5;
    padding: 1;
    width: 1fr;
    margin-right: 2;
}

.version-box-latest {
    border: tall #C89A30;
}

.version-lbl {
    color: #344252;
    height: 1;
}

.version-num {
    color: #E8D5A8;
    text-style: bold;
    height: 1;
}

.version-num-latest {
    color: #C89A30;
    text-style: bold;
    height: 1;
}

.update-ok {
    background: #060E08;
    border: tall #0A2014;
    color: #2A7A4A;
    height: 3;
    padding: 0 1;
}

.update-available {
    background: #0D0A00;
    border: tall #C89A30;
    color: #C89A30;
    height: 3;
    padding: 0 1;
}

/* ── Unlock / create vault screens ───────────────────────────── */

#unlock-box {
    background: #0F1218;
    border: tall #1A2430;
    width: 52;
    height: auto;
    padding: 2;
    margin: 4 0;
}

#unlock-icon {
    color: #C89A30;
    text-style: bold;
    text-align: center;
    height: 3;
}

#unlock-title {
    color: #E8D5A8;
    text-style: bold;
    text-align: center;
    height: 1;
    margin-bottom: 1;
}

#unlock-subtitle {
    color: #344252;
    text-align: center;
    height: 1;
    margin-bottom: 1;
}

#unlock-error {
    color: #CC3333;
    height: 1;
    text-align: center;
}

/* ── Add/Edit entry overlay forms ─────────────────────────────── */
/* The forms reuse #unlock-box but lack the unlock screens' centering
   wrappers, so centre the box here. Top-anchored (not middle): the
   form is taller than a 30-row terminal and must scroll, not clip. */

AddEntryScreen ScrollableContainer,
EditEntryScreen ScrollableContainer {
    align: center top;
}

AddEntryScreen #unlock-box,
EditEntryScreen #unlock-box {
    margin: 1 0;
}

#add-pw-strength,
#edit-pw-strength {
    margin: 0 0 1 0;
}

/* ── Footer ───────────────────────────────────────────────────── */

Footer {
    background: #080A0E;
    border-top: tall #141C24;
    color: #2E3C4A;
}

Footer > .footer--key {
    background: #0D0A00;
    color: #C89A30;
}

/* ── Scrollbars ───────────────────────────────────────────────── */

ScrollBar {
    background: #0B0D12;
    color: #1A2430;
}

ScrollBar:hover {
    color: #344252;
}

/* ── Shared screen chrome (Obsidian Tactical v3) ─────────────── */

NyxTopBar {
    width: 100%;
    height: 1;
    background: #04060C;
    color: #1E2D3D;
    text-align: center;
    padding: 0 1;
}

NyxBottomBar {
    width: 100%;
    height: 1;
    background: #04060C;
    color: #1E2D3D;
    text-align: center;
    padding: 0 1;
}

NyxBackground {
    width: 100%;
    height: 100%;
    color: #141E28;
    background: transparent;
    padding: 0 1;
}

NyxCornerInfo {
    width: auto;
    height: auto;
    color: #0E1820;
    background: transparent;
    padding: 0 1;
}

NyxSep {
    width: 100%;
    height: 1;
    background: transparent;
    color: #C89A30;
    text-align: center;
    margin: 0 0 1 0;
}

.nyx-corners-top {
    width: 100%;
    height: auto;
    background: transparent;
}

.nyx-corners-bot {
    width: 100%;
    height: auto;
    background: transparent;
}

.corner-spacer {
    width: 1fr;
    height: 1;
    background: transparent;
}

/* UnlockScreen / CreateVaultScreen overlay layout */
#unlock-ui {
    width: 100%;
    height: 100%;
    background: transparent;
}
#create-ui {
    width: 100%;
    height: 100%;
    background: transparent;
}
#unlock-center {
    width: 100%;
    height: 1fr;
    align: center top;
    overflow-y: auto;
}
#create-center {
    width: 100%;
    height: 1fr;
    align: center top;
    overflow-y: auto;
}
#unlock-box {
    width: 52;
    height: auto;
    background: #08111A;
    border: tall #1C2A3A;
    padding: 2 3;
}
#create-box {
    width: 52;
    height: auto;
    background: #08111A;
    border: tall #1C2A3A;
    padding: 2 3;
}

/* ── Recovery screen QR split layout ─────────────────────── */

#recovery-main {
    width: 100%;
    height: 1fr;
}

#recovery-left {
    width: 1fr;
    height: 100%;
    overflow-y: auto;
}

#qr-panel {
    width: 46;
    height: 100%;
    border-left: tall #1A2535;
    background: #FFFFFF;
    align: center top;
    padding: 1 0 0 0;
    overflow: hidden hidden;
}

#qr-placeholder {
    color: #888888;
    text-align: center;
    width: auto;
    height: auto;
    background: #FFFFFF;
    margin-top: 2;
}

#totp-output {
    width: auto;
    height: auto;
    background: #FFFFFF;
    color: #000000;
    padding: 0;
}

/* ── TOTP QR overlay screen ──────────────────────────────────── */

TotpQrOverlay {
    align: center middle;
    background: #060810;
}

#qr-overlay-box {
    width: auto;
    height: auto;
    background: #FFFFFF;
    border: tall #C89A30;
    padding: 0 2;
}

#qr-overlay-title {
    width: 100%;
    text-align: center;
    color: #060810;
    text-style: bold;
}

#qr-overlay-account {
    width: 100%;
    text-align: center;
    color: #555555;
}

#qr-overlay-qr {
    width: auto;
    height: auto;
    background: #FFFFFF;
    color: #000000;
}

#qr-overlay-secret {
    width: 100%;
    text-align: center;
    color: #060810;
    text-style: bold;
}

#qr-overlay-hint {
    width: 100%;
    text-align: center;
    color: #C89A30;
    background: #FFFFFF;
}
